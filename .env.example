# ── NVIDIA Vision API ──────────────────────────────────
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── Bambu Lab Cloud Credentials ────────────────────────
# Run bambu_login.py to generate these automatically
BAMBU_TOKEN=your_bambu_bearer_token_here
BAMBU_DEVICE_ID=your_printer_serial_here
BAMBU_CLOUD_HOST=eu.mqtt.bambulab.com

# ── Local MQTT (optional — set USE_LOCAL_MQTT=True) ────
USE_LOCAL_MQTT=False
PRINTER_LOCAL_IP=192.168.1.100
PRINTER_ACCESS_CODE=your_local_access_code_here

# ── Hardware (ESP32 Actuator Controller) ───────────────
ESP32_IP=10.254.244.107

# ── System Flags ───────────────────────────────────────
MOCK_MODE=False
